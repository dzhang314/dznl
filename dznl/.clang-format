---
################################################################################
# This .clang-format file is for modern C++.                                   #
################################################################################

Language: Cpp
DisableFormat: false
Standard: Cpp11
Cpp11BracedListStyle: true

################################################################################
# Limit lines to 80 characters to aid side-by-side editing.                    #
################################################################################

ColumnLimit: 80

################################################################################
# Indentation style options.                                                   #
################################################################################

IndentWidth: 4
ContinuationIndentWidth: 8
ConstructorInitializerIndentWidth: 8
UseTab: Never
NamespaceIndentation: All
FixNamespaceComments: true
AccessModifierOffset: -4

################################################################################
# Line break style options.                                                    #
################################################################################

AllowAllParametersOfDeclarationOnNextLine: true
AllowShortBlocksOnASingleLine: true       ######################################
AllowShortCaseLabelsOnASingleLine: true   # Compress single-statement blocks   #
AllowShortFunctionsOnASingleLine: All     # and functions to one line whenever #
AllowShortIfStatementsOnASingleLine: true # they fit within the column limit.  #
AllowShortLoopsOnASingleLine: true        ######################################
AlwaysBreakAfterDefinitionReturnType: None
AlwaysBreakAfterReturnType: None
BinPackArguments: true
BinPackParameters: false
BreakBeforeBraces: Attach
BreakBeforeTernaryOperators: true
BreakConstructorInitializers: BeforeColon
ConstructorInitializerAllOnOneLineOrOnePerLine: true
KeepEmptyLinesAtTheStartOfBlocks: false

################################################################################
# Alignment style options.                                                     #
################################################################################

AlignAfterOpenBracket: Align
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignEscapedNewlines: Left
AlignOperands: true
AlignTrailingComments: true

################################################################################
# Always use "void *ptr" instead of "void* ptr".                               #
################################################################################

DerivePointerAlignment: false
PointerAlignment: Right

################################################################################
# Sort groups of adjacent "#include" directives and "using" declarations.      #
################################################################################

IncludeBlocks: Preserve
SortIncludes: true
SortUsingDeclarations: true

################################################################################
# Always use spaces around assignment operators, control flow constructs, and  #
# single-line comments.                                                        #
################################################################################

SpaceBeforeAssignmentOperators: true
SpaceBeforeParens: ControlStatements
SpacesBeforeTrailingComments: 1

################################################################################
# Don't use extraneous spaces inside parentheses/brackets or around C casts.   #
################################################################################

SpacesInParentheses: false
SpaceInEmptyParentheses: false
SpacesInSquareBrackets: false
SpacesInAngles: false
SpacesInContainerLiterals: false
SpacesInCStyleCastParentheses: false
SpaceAfterCStyleCast: false

################################################################################
# Template style options.                                                      #
################################################################################

AlwaysBreakTemplateDeclarations: true
SpaceAfterTemplateKeyword: true

################################################################################
# Default style options inherited from the "LLVM" predefined style.            #
################################################################################

AlwaysBreakBeforeMultilineStrings: false
BreakBeforeBinaryOperators: None
BreakBeforeInheritanceComma: false
BreakStringLiterals: true
CommentPragmas: 'a^'
CompactNamespaces: false
ExperimentalAutoDetectBinPacking: false
ForEachMacros: []
IncludeCategories: []
IncludeIsMainRegex: '(Test)?$'
IndentCaseLabels: false
IndentPPDirectives: None
IndentWrappedFunctionNames: false
MacroBlockBegin: ''
MacroBlockEnd:   ''
MaxEmptyLinesToKeep: 1
PenaltyBreakAssignment: 2
PenaltyBreakBeforeFirstCallParameter: 19
PenaltyBreakComment: 300
PenaltyBreakFirstLessLess: 120
PenaltyBreakString: 1000
PenaltyExcessCharacter: 1000000
PenaltyReturnTypeOnItsOwnLine: 60
RawStringFormats: []
ReflowComments:  true
...
